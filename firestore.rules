rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin check — reads custom claim from signed JWT (cannot be forged)
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // User profiles
    match /users/{userId} {
      // Users can read their own doc
      // Admins can read any doc AND query/list the collection (for User Lookup)
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());

      // Create: own doc with required fields, OR admin can create any (test users)
      allow create: if isAdmin()
                    || (request.auth != null && request.auth.uid == userId
                        && request.resource.data.subscriptionStatus == 'trial'
                        && request.resource.data.keys().hasAll(['email', 'trialStartDate', 'subscriptionStatus', 'createdAt']));

      // Update: admin can change anything; user can change non-protected fields;
      // user can change protected fields ONLY during trial code redemption.
      // Note: subscriptionStatus changes to 'active'/'expired' are handled server-side
      // by Cloud Functions (Stripe webhook) which use admin SDK and bypass these rules.
      allow update: if request.auth != null && (
                      isAdmin()
                      || (request.auth.uid == userId
                          && !request.resource.data.diff(resource.data).affectedKeys()
                              .hasAny(['subscriptionStatus', 'trialStartDate', 'createdAt',
                                       'stripeCustomerId', 'stripeSubscriptionId', 'subscribedAt',
                                       'subscriptionPeriodEnd', 'mfaEnabled', 'lastMFAVerification',
                                       'invitedBy', 'registrationCodes', 'registrationCodesGenerated']))
                      || (request.auth.uid == userId
                          && request.resource.data.subscriptionStatus == 'trial'
                          && 'trialCode' in request.resource.data
                          && request.resource.data.trialCode is string
                          && exists(/databases/$(database)/documents/trialCodeLookup/$(request.resource.data.trialCode))
                          && get(/databases/$(database)/documents/trialCodeLookup/$(request.resource.data.trialCode)).data.active == true)
                    );

      // Delete: admin only (for test user cleanup)
      allow delete: if isAdmin();

      // MFA secrets subcollection — only Cloud Functions (admin SDK) can access
      // Client-side code NEVER reads/writes TOTP secrets directly
      match /mfaSecrets/{docId} {
        allow read, write: if false;
      }
    }

    // User finance data
    // Note: User data is stored as JSON string in the 'data' field, so we cannot
    // check sharedWith in security rules. Shared access is checked by the Cloud Functions
    // which have admin access and can read the JSON. For basic access, we verify via
    // a separate sharedWithUids array stored at the document root level.
    match /userData/{userId} {
      // ── RBAC (sharedRoles map, maintained by Cloud Functions + the
      //    storage adapter alongside the JSON sharedWith entries) ──
      //
      // Direct document reads are reserved for roles that may see the whole
      // dataset: viewer / partner / full (and legacy shares without a role).
      // Partial-view roles (companion / advisor) get NO direct access — they
      // read through the getSharedSnapshot Cloud Function, which filters
      // server-side.
      function myRole() {
        return ('sharedRoles' in resource.data
                && request.auth.uid in resource.data.sharedRoles)
               ? resource.data.sharedRoles[request.auth.uid].role
               : null;
      }

      function hasLegacyShare() {
        // Shares created before roles existed: full-view by construction.
        return 'sharedWithUids' in resource.data
               && request.auth.uid in resource.data.sharedWithUids
               && !('sharedRoles' in resource.data
                    && request.auth.uid in resource.data.sharedRoles);
      }

      function hasFullViewAccess() {
        return myRole() in ['viewer', 'partner', 'full'] || hasLegacyShare();
      }

      function hasEditRole() {
        return myRole() in ['partner', 'full']
               || ('sharedWithEdit' in resource.data
                   && request.auth.uid in resource.data.sharedWithEdit
                   && hasLegacyShare());
      }

      // A shared editor must never touch the ACL fields — otherwise an
      // invited editor could grant/revoke access (owner-only capability).
      function aclFieldsUnchanged() {
        return request.resource.data.get('sharedWithUids', []) == resource.data.get('sharedWithUids', [])
               && request.resource.data.get('sharedWithEdit', []) == resource.data.get('sharedWithEdit', [])
               && request.resource.data.get('sharedRoles', {}) == resource.data.get('sharedRoles', {});
      }

      // Users read own data; admin reads any; full-view shared roles can read
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin() || hasFullViewAccess());

      // Users write own data (if not expired); admin writes any; shared
      // editors (partner/full) can write but cannot alter ACLs
      allow write: if request.auth != null && (
                     isAdmin()
                     || (request.auth.uid == userId
                         && (!exists(/databases/$(database)/documents/users/$(userId))
                             || get(/databases/$(database)/documents/users/$(userId)).data.subscriptionStatus != 'expired'))
                     || (hasEditRole() && aclFieldsUnchanged())
                   );
    }

    // Reverse index written on invite acceptance — lets a sharee discover
    // who shared with them without any access to the owner's document.
    match /shares/{shareId} {
      allow read: if request.auth != null
                   && (resource.data.shareeUid == request.auth.uid
                       || resource.data.ownerUid == request.auth.uid);
      // Written only by Cloud Functions (admin SDK bypasses rules).
      allow write: if false;
    }

    // Invites collection — stores pending invites indexed by email
    match /invites/{inviteId} {
      // Only the inviter or invitee can read an invite
      allow read: if request.auth != null
                   && (resource.data.inviterUid == request.auth.uid
                       || resource.data.inviteeEmail == request.auth.token.email);

      // Only the owner (inviter) can create/update/delete invites
      allow create: if request.auth != null && request.resource.data.inviterUid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.inviterUid == request.auth.uid;
    }

    // Invite lookup by email — allows users to find invites sent to them
    match /invitesByEmail/{email} {
      // Users can read their own invite list
      allow read: if request.auth != null && request.auth.token.email == email;
      // Only system (via cloud functions) or admin can write
      allow write: if isAdmin();
    }

    // Trial codes management — admin only
    match /trialCodes/{codeId} {
      allow read, write: if isAdmin();
    }

    // Trial code lookup — any authenticated user can read (code string is the secret),
    // only admin can write
    match /trialCodeLookup/{codeString} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // API keys — only Cloud Functions (admin SDK) can read/write.
    // Keys are hashed; raw key is never stored. Lookup is by hash.
    match /apiKeys/{keyId} {
      allow read, write: if false;
    }

    // Plaid items — access_tokens stored here, NEVER readable by client
    match /plaidItems/{itemId} {
      allow read, write: if false;
    }

    // Telemetry collection — users can create their own logs for troubleshooting
    // Logs are auto-deleted after 30 days by Cloud Function
    match /telemetry/{logId} {
      // Users can create logs for themselves only
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      // Only admin can read (for troubleshooting) and delete (cleanup)
      allow read, delete: if isAdmin();
    }

    // Registration invite codes — authenticated users can read (to check status),
    // only Cloud Functions (admin SDK) can write
    match /registrationCodes/{codeString} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Waitlist — Cloud Functions handle all writes via admin SDK
    // No client reads needed (status checked via Cloud Function)
    match /waitlist/{email} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Ad-attribution events — landing_view / cta_click fired anonymously from
    // the /switch landing page. Writes happen server-side via logAdEvent
    // (admin SDK bypasses these rules). Reads are admin-only for the
    // attribution funnel view in the admin panel.
    match /adEvents/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // User activity markers — one doc per (user, UTC day) used to compute
    // DAU/MAU. No financial data; just {uid, date, timestamps, expiresAt}.
    // Doc ID convention: `{YYYY-MM-DD}_{uid}` — idempotent across devices.
    // Users can write only markers embedding their own uid. Admin reads for
    // the Active Users panel. 90-day TTL cleanup via expiresAt.
    match /userActivity/{docId} {
      allow read: if isAdmin();
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.date is string;
      allow update: if request.auth != null
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Content posts, written server-side only (Cloud Functions via the Admin SDK
    // bypass these rules); clients can never write. Published posts are
    // world-readable so the site can render them; drafts and non-existent docs
    // read as denied.
    match /posts/{slug} {
      allow read: if resource != null && resource.data.status == 'publish';
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
