rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles — only the user can read/write their own doc
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Create: must be own doc, must start as trial, required fields present
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.subscriptionStatus == 'trial'
                    && request.resource.data.keys().hasAll(['email', 'trialStartDate', 'subscriptionStatus', 'createdAt']);

      // Update: cannot modify subscriptionStatus, trialStartDate, or createdAt
      allow update: if request.auth != null && request.auth.uid == userId
                    && (!request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['subscriptionStatus', 'trialStartDate', 'createdAt']));
    }

    // User finance data — only the user can access their own data
    match /userData/{userId} {
      // Read always allowed (for data export even when expired)
      allow read: if request.auth != null && request.auth.uid == userId;

      // Write blocked if subscription expired
      allow write: if request.auth != null && request.auth.uid == userId
                   && (
                     !exists(/databases/$(database)/documents/users/$(userId))
                     || get(/databases/$(database)/documents/users/$(userId)).data.subscriptionStatus != 'expired'
                   );
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
