{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": ".",
    "predeploy": [
      "node scripts/verify-cloud-mode.js"
    ],
    "ignore": [
      "node_modules/**",
      "data/**",
      "server.js",
      "package.json",
      "package-lock.json",
      "firebase-service-account.json",
      "firestore.rules",
      "firestore.indexes.json",
      ".firebaserc",
      ".claude/**",
      "*.md",
      "*.db*",
      "functions/**",
      "scripts/**"
    ],
    "rewrites": [
      {
        "source": "/api/log-ad-event",
        "function": "logAdEvent"
      },
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/app",
        "destination": "/app.html"
      },
      {
        "source": "/app/**",
        "destination": "/app.html"
      },
      {
        "source": "/login",
        "destination": "/login.html"
      },
      {
        "source": "/accept-invite",
        "destination": "/accept-invite.html"
      },
      {
        "source": "/oauth",
        "destination": "/oauth.html"
      },
      {
        "source": "/delete-account",
        "destination": "/delete-account.html"
      },
      {
        "source": "/switch",
        "destination": "/switch.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|mjs|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "/",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "/@(app|login|accept-invite|oauth|delete-account|switch)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "/app/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|png|gif|webp|svg|ico|avif)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "**/*.@(woff|woff2|ttf|otf|eot)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
